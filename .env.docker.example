# Docker Environment Variables
# Copy this to .env and update values

# ======================
# Server Configuration
# ======================
NODE_ENV=production
PORT=5000

# ======================
# Database Configuration
# ======================
# For Production (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aiStudy?retryWrites=true&w=majority

# For Local Docker (MongoDB Container)
# MONGODB_URI=mongodb://admin:password@mongodb:27017/aiStudy?authSource=admin

# ======================
# Authentication
# ======================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ======================
# Client Configuration
# ======================
CLIENT_URL=https://yourdomain.com
# For development: http://localhost:5173

# ======================
# AI Services Configuration
# ======================
# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# ======================
# Email Configuration (Gmail)
# ======================
EMAIL_USER=your-email@gmail.com
# Use App Password, not regular password
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ======================
# MongoDB Admin Credentials (for docker-compose only)
# ======================
MONGO_USERNAME=admin
MONGO_PASSWORD=your-secure-admin-password-change-this
MONGO_DB_NAME=aiStudy

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=info
# Development: debug, production: info or warn
